PORT=3000
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
MAKE_WEBHOOK_TRANSPORT_QUOTE=https://hook.make.com/your-transport-quote-webhook-id-here
MAKE_WEBHOOK_EMAIL_AUTOMATION=https://hook.make.com/your-email-automation-webhook-id-here
MAKE_WEBHOOK_CONTACT_FORM=https://hook.make.com/your-contact-form-webhook-id-here
MAKE_WEBHOOK_DEMO_REQUEST=https://hook.make.com/your-demo-request-webhook-id-here
MAKE_WEBHOOK_CRM_AI=https://hook.make.com/your-cm-ai-webhook-id-here

# Optional: OpenAI API key for AI Email → Transport Order Extraction (server-side only, never exposed to frontend)
# If not set, demo uses fallback pattern matching
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Prompt for "Use example email" in email-demo. AI generates a random transport email from this.
# e.g. A request from Berlin to Munich with 5 pallets, pickup tomorrow morning
SAMPLE_EMAIL_PROMPT=

# Optional: Make.com webhook for extracted orders (email-demo). Extracted JSON is POSTed here.
MAKE_WEBHOOK_EMAIL=https://hook.make.com/your-email-extraction-webhook-id

# Optional: Supabase (auth + feature status). Get from Supabase project Settings > API.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here


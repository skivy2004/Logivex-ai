PORT=3000
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# n8n workflow webhooks (self-hosted n8n instance)
N8N_WEBHOOK_TRANSPORT_QUOTE=https://your-n8n.example.com/webhook/transport-quote
N8N_WEBHOOK_CONTACT=https://your-n8n.example.com/webhook/contact
N8N_WEBHOOK_AUTOMATION_INTAKE=https://your-n8n.example.com/webhook/automation-intake
N8N_WEBHOOK_EMAIL=https://your-n8n.example.com/webhook/email-extraction
N8N_WEBHOOK_EMAIL_AUTOMATION=https://your-n8n.example.com/webhook/email-automation
N8N_WEBHOOK_DEMO_REQUEST=https://your-n8n.example.com/webhook/demo-request
N8N_WEBHOOK_CRM_AI=https://your-n8n.example.com/webhook/crm-ai

# Optional: OpenAI API key for AI Email → Transport Order Extraction (server-side only, never exposed to frontend)
# If not set, demo uses fallback pattern matching
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Prompt for "Use example email" in email-demo. AI generates a random transport email from this.
# e.g. A request from Berlin to Munich with 5 pallets, pickup tomorrow morning
SAMPLE_EMAIL_PROMPT=

# Optional: Supabase (auth + feature status). Get from Supabase project Settings > API.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
